# Environment Variables Example
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=5000

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trafficjamz
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

MONGODB_URI=mongodb://localhost:27017/trafficjamz

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this

# CORS
CORS_ORIGIN_DEV=http://localhost:5175
CORS_ORIGIN_PROD=http://localhost:8080

# Email Service (Brevo/SendinBlue)
EMAIL_ENABLED=true
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=noreply@trafficjamz.com
EMAIL_FROM_NAME=TrafficJamz

# SMS Service (Twilio)
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+12025551234

# Frontend URL (for invitation links)
FRONTEND_URL=http://localhost:5175

# WebRTC/MediaSoup
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_influxdb_token
INFLUXDB_ORG=trafficjamz
INFLUXDB_BUCKET=locations

# AWS (if using S3 for file storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=trafficjamz-uploads

# Feature Flags
DISABLE_AUDIO_SIGNALING=false
