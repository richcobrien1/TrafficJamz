{
  "buildCommand": "if [ -d ../jamz-client-vite ]; then cd ../jamz-client-vite; else cd jamz-client-vite; fi && npm install && npm run build",
  "outputDirectory": "jamz-client-vite/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
