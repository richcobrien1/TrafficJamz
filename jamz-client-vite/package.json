{
  "name": "jamz-client-vite",
  "private": true,
  "version": "1.0.12",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "TrafficJamz",
  "description": "Real-time group communication with GPS, music sync, and voice chat",
  "scripts": {
    "dev": "vite --port 5174",
    "dev:host": "vite --host --port 5175",
    "build": "vite build",
    "build:electron": "cross-env ELECTRON=true vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5174 && cross-env ELECTRON_START_URL=http://localhost:5174 electron .\"",
    "electron:build": "npm run build:electron && electron-builder",
    "electron:build:win": "npm run build:electron && electron-builder --win",
    "electron:build:mac": "npm run build:electron && electron-builder --mac",
    "electron:build:linux": "npm run build:electron && electron-builder --linux",
    "cap:sync": "npm run build && npx cap sync",
    "cap:sync:android": "npm run build && npx cap sync android",
    "cap:sync:ios": "npm run build && npx cap sync ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npm run build && npx cap sync android && npx cap run android",
    "cap:run:ios": "npm run build && npx cap sync ios && npx cap run ios",
    "mobile:android": "npm run build && npx cap sync android && npx cap open android",
    "mobile:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "build:all": "bash build-all.sh --all",
    "build:web": "bash build-all.sh --web",
    "build:mobile": "bash build-all.sh --mobile",
    "build:desktop": "bash build-all.sh --electron",
    "test": "playwright test",
    "test:quick": "node tests/quick-test.mjs",
    "test:smoke": "playwright test smoke.spec.js",
    "test:auth": "playwright test auth.spec.js",
    "test:navigation": "playwright test navigation.spec.js",
    "test:groups": "playwright test groups.spec.js",
    "test:audio": "playwright test audio.spec.js",
    "test:location": "playwright test location.spec.js",
    "test:music": "playwright test music.spec.js",
    "test:build": "playwright test mobile-build.spec.js",
    "test:critical": "playwright test audio.spec.js location.spec.js music.spec.js",
    "test:chrome": "playwright test --project=chromium-desktop",
    "test:safari": "playwright test --project=webkit-desktop",
    "test:firefox": "playwright test --project=firefox-desktop",
    "test:mobile": "playwright test --project=mobile-safari --project=mobile-chrome-ios --project=mobile-chrome-android",
    "test:electron": "playwright test --project=electron electron.spec.js",
    "test:electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5174 && playwright test --project=electron electron.spec.js\"",
    "test:all": "node tests/run-all-tests.mjs",
    "test:smoke:prod": "TEST_URL=https://jamz.v2u.us playwright test smoke.spec.js",
    "test:all:prod": "TEST_URL=https://jamz.v2u.us playwright test",
    "test:report": "playwright show-report test-reports/html",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@clerk/clerk-react": "^5.0.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "axios": "^1.6.0",
    "framer-motion": "^11.0.0",
    "mapbox-gl": "^3.0.0",
    "mediasoup-client": "^3.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.20.0",
    "socket.io-client": "^4.7.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "@playwright/test": "^1.49.1",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "39.2.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "rcedit": "^5.0.2",
    "vite": "^5.4.20",
    "wait-on": "^8.0.1"
  },
  "overrides": {
    "@babel/parser": "^7.25.0",
    "@babel/core": "^7.25.0"
  },
  "build": {
    "appId": "com.trafficjamz.app",
    "productName": "TrafficJamz",
    "copyright": "Copyright © 2025 TrafficJamz",
    "afterPack": "scripts/afterPack.cjs",
    "protocols": {
      "name": "trafficjamz",
      "schemes": [
        "trafficjamz"
      ]
    },
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.*",
      "package.json",
      "!node_modules"
    ],
    "buildDependenciesFromSource": false,
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "forceCodeSigning": false
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.social-networking"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "forceCodeSigning": false
  }
}
