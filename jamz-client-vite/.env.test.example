# TrafficJamz Test Environment Variables
# Copy this file to .env.test and fill in your test credentials
# DO NOT commit .env.test to git!

# Test URL (production or local)
TEST_URL=https://jamz.v2u.us

# Test User Credentials (create a dedicated test account)
TEST_USER_EMAIL=your-test-email@example.com
TEST_USER_PASSWORD=YourSecureTestPassword123!

# Clerk Configuration (from your Clerk dashboard)
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Music Platform Test Credentials (optional, for music playback tests)
SPOTIFY_TEST_EMAIL=
SPOTIFY_TEST_PASSWORD=
APPLE_MUSIC_TOKEN=
